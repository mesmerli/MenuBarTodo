{
  "name": "menubar-todo",
  "version": "1.4.2-build.000012",
  "description": "A minimal menubar todo app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "node bump-build.js && electron-builder --dir",
    "dist": "node bump-build.js && electron-builder",
    "dist-run": "node bump-build.js && electron-builder && start \"\" \"dist\\win-unpacked\\MenuBar Todo.exe\"",
    "pack-models": "tar -czf models/en.tar.gz -C models/en . && tar -czf models/zh.tar.gz -C models/zh .",
    "test": "playwright test"
  },
  "build": {
    "appId": "com.mesme.menubartodo",
    "productName": "MenuBar Todo",
    "compression": "maximum",
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "taskmanager.js",
      "archive.js",
      "locales.js",
      "index.html",
      "taskmanager.html",
      "archive.html",
      "about.html",
      "style.css",
      "taskmanager.css",
      "icon.png",
      "package.json",
      "lib/"
    ],
    "win": {
      "target": [
        "nsis",
        "appx"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "MenuBar Todo"
    },
    "appx": {
      "identityName": "mesmerli.MenuBarTodo",
      "publisher": "CN=B50F36C9-7E5E-4652-A715-0185D35ADE64",
      "publisherDisplayName": "mesmerli",
      "displayName": "MenuBar Todo",
      "backgroundColor": "#1a1a1e",
      "showNameOnTiles": true,
      "languages": [
        "zh-TW",
        "en-US"
      ],
      "addAutoLaunchExtension": true
    },
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      "models/*.tar.gz"
    ]
  },
  "keywords": [],
  "author": "mesmerli",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "vosk-browser": "^0.0.8"
  }
}